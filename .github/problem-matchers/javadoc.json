{
  "problemMatcher": [
    {
      "owner": "javadoc-doclint",
      "severity": "error",
      "pattern": [
        {
          "regexp": "\\s+/__w/spark/spark/(\\S+):(\\d+):(\\d+):\\s+([^:]+):\\s+(reference not found)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
