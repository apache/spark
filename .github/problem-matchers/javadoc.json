{
  "problemMatcher": [
    {
      "owner": "javadoc-doclint",
      "severity": "error",
      "pattern": [
        {
          "regexp": "(?:^|(?<=\\s))([/a-zA-Z](?:(?!/target/)\\S)*):(\\d+):(\\d+):\\s+error:\\s+(.+)",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      ]
    }
  ]
}
