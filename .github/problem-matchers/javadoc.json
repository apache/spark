{
  "problemMatcher": [
    {
      "owner": "javadoc-doclint",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\[error\\]\\s+(?!\\S*/target/java/org/apache/spark/)(\\S+):(\\d+):(\\d+):\\s+([^:]+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
