{
  "problemMatcher": [
    {
      "owner": "javadoc-doclint",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(?:\u001b\\[[0-9;]*m)*\\[(?:\u001b\\[[0-9;]*m)*error(?:\u001b\\[[0-9;]*m)*\\](?:\u001b\\[[0-9;]*m)*\\s+(?!\\S*\\/target\\/java\\/org\\/apache\\/spark\\/)(?:\u001b\\[[0-9;]*m)*(\\S+):(\\d+):(\\d+):\\s+(?:\u001b\\[[0-9;]*m)*([^:]+):\\s+(?:\u001b\\[[0-9;]*m)*(.+?)(?:\u001b\\[[0-9;]*m)*$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
