-- !query
SELECT r.req_ts, r.seq, d.version
FROM requests r ASOF JOIN deploys d
  MATCH_CONDITION ((r.req_ts, r.seq) >= (d.deploy_ts, d.seq))
  ON r.service = d.service
ORDER BY r.req_ts, r.seq
-- !query analysis
Sort [req_ts#x ASC NULLS FIRST, seq#x ASC NULLS FIRST], true
+- Project [req_ts#x, seq#x, version#x]
   +- AsOfJoin (named_struct(req_ts, req_ts#x, seq, seq#x) >= named_struct(deploy_ts, deploy_ts#x, seq, seq#x)), (service#x = service#x), Inner
      :- SubqueryAlias r
      :  +- SubqueryAlias requests
      :     +- View (`requests`, [req_ts#x, seq#x, service#x])
      :        +- Project [cast(col1#x as timestamp) AS req_ts#x, cast(col2#x as int) AS seq#x, cast(col3#x as string) AS service#x]
      :           +- LocalRelation [col1#x, col2#x, col3#x]
      +- SubqueryAlias d
         +- SubqueryAlias deploys
            +- View (`deploys`, [deploy_ts#x, seq#x, service#x, version#x])
               +- Project [cast(col1#x as timestamp) AS deploy_ts#x, cast(col2#x as int) AS seq#x, cast(col3#x as string) AS service#x, cast(col4#x as string) AS version#x]
                  +- LocalRelation [col1#x, col2#x, col3#x, col4#x]


-- !query
SELECT e.event_time, e.tenant_id, d.effective_time
FROM VALUES (TIMESTAMP '2026-06-29 11:00:00', 1) AS e(event_time, tenant_id) ASOF JOIN
     VALUES (TIMESTAMP '2026-06-29 09:00:00', 1) AS d(effective_time, tenant_id)
  MATCH_CONDITION (e.event_time >= d.effective_time + INTERVAL 1 HOUR)
  ON e.tenant_id = d.tenant_id
-- !query analysis
Project [event_time#x, tenant_id#x, effective_time#x]
+- AsOfJoin (event_time#x >= cast(effective_time#x + INTERVAL '01' HOUR as timestamp)), (tenant_id#x = tenant_id#x), Inner
   :- SubqueryAlias e
   :  +- LocalRelation [event_time#x, tenant_id#x]
   +- SubqueryAlias d
      +- LocalRelation [effective_time#x, tenant_id#x]


