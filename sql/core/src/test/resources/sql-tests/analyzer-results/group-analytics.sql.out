            :        :              +- Project [a#x, b#x]
            :        :                 +- SubqueryAlias aggSrc
            :        :                    +- LocalRelation [a#x, b#x]
            :        +- SubqueryAlias sub12
            :           +- View (`sub12`, [x#x])
            :              +- Project [cast(x#x as int) AS x#x]
            :                 +- Project [x#x]
            :                    +- SubqueryAlias sub12
            :                       +- LocalRelation [x#x]
            +- SubqueryAlias subouter4
               +- View (`subOuter4`, [col1#x, col2#x])
                  +- Project [cast(col1#x as int) AS col1#x, cast(col2#x as int) AS col2#x]
                     +- Project [col1#x, col2#x]
                        +- SubqueryAlias subOuter4
                           +- LocalRelation [col1#x, col2#x]


-- !query
SELECT a, SUM(b) AS s
FROM aggSrc
