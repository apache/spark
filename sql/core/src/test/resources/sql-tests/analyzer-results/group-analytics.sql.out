                        +- LocalRelation [a#x, b#x]


-- !query
SELECT a, b, SUM(b) AS sb
FROM aggSrc
GROUP BY GROUPING SETS ((a, b), (a))
HAVING SUM(b) > 15
ORDER BY a, b
