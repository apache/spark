-- !query
SELECT t.trade_time, t.symbol, q.bid_price,
       row_number() OVER (PARTITION BY t.symbol ORDER BY t.trade_time) AS rn
FROM trades t ASOF JOIN quotes q
  MATCH_CONDITION (t.trade_time >= q.quote_time)
  ON t.symbol = q.symbol
ORDER BY t.symbol, t.trade_time
-- !query analysis
Sort [symbol#x ASC NULLS FIRST, trade_time#x ASC NULLS FIRST], true
+- Project [trade_time#x, symbol#x, bid_price#x, rn#x]
   +- Project [trade_time#x, symbol#x, bid_price#x, rn#x, rn#x]
      +- Window [row_number() windowspecdefinition(symbol#x, trade_time#x ASC NULLS FIRST, specifiedwindowframe(RowFrame, unboundedpreceding$(), currentrow$())) AS rn#x], [symbol#x], [trade_time#x ASC NULLS FIRST]
         +- Project [trade_time#x, symbol#x, bid_price#x]
            +- AsOfJoin (trade_time#x >= quote_time#x), (symbol#x = symbol#x), Inner
               :- SubqueryAlias t
               :  +- SubqueryAlias trades
               :     +- View (`trades`, [trade_time#x, symbol#x, quantity#x])
               :        +- Project [cast(col1#x as timestamp) AS trade_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as int) AS quantity#x]
