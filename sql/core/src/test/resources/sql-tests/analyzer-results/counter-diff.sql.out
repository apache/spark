FROM VALUES
  (1, TIMESTAMP '2026-01-01 00:05:00', 100),
  (2, TIMESTAMP '2026-01-01 00:01:00', 200)
AS tab(t, st, c)
-- !query analysis
Project [diff#x]
+- Project [c#x, st#x, t#x, diff#x, diff#x]
   +- Window [counter_diff(c#x, st#x, Some(UTC)) windowspecdefinition(t#x ASC NULLS FIRST, specifiedwindowframe(RowFrame, unboundedpreceding$(), currentrow$())) AS diff#x], [t#x ASC NULLS FIRST]
      +- Project [c#x, st#x, t#x]
         +- SubqueryAlias tab
            +- LocalRelation [t#x, st#x, c#x]


