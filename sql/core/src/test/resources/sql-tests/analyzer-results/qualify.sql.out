CREATE OR REPLACE TEMPORARY VIEW dealer AS SELECT * FROM VALUES
  (100, 'Fremont', 'Honda Civic', 10),
  (100, 'Fremont', 'Honda Accord', 15),
  (100, 'Fremont', 'Honda CRV', 7),
  (200, 'Dublin', 'Honda Civic', 20),
  (200, 'Dublin', 'Honda Accord', 10),
  (200, 'Dublin', 'Honda CRV', 3),
  (300, 'San Jose', 'Honda Civic', 5),
  (300, 'San Jose', 'Honda Accord', 8)
AS dealer(id, city, car_model, quantity)
-- !query analysis
CreateViewCommand `dealer`, SELECT * FROM VALUES
  (100, 'Fremont', 'Honda Civic', 10),
  (100, 'Fremont', 'Honda Accord', 15),
  (100, 'Fremont', 'Honda CRV', 7),
  (200, 'Dublin', 'Honda Civic', 20),
  (200, 'Dublin', 'Honda Accord', 10),
  (200, 'Dublin', 'Honda CRV', 3),
  (300, 'San Jose', 'Honda Civic', 5),
  (300, 'San Jose', 'Honda Accord', 8)
AS dealer(id, city, car_model, quantity), false, true, LocalTempView, UNSUPPORTED, true
   +- Project [id#x, city#x, car_model#x, quantity#x]
      +- SubqueryAlias dealer
         +- LocalRelation [id#x, city#x, car_model#x, quantity#x]


-- !query
SELECT city, car_model, RANK() OVER (PARTITION BY car_model ORDER BY quantity) AS rank
FROM dealer
QUALIFY rank = 1
ORDER BY car_model, city
