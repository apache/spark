+- Project [t1a#x, t1b#x, t1c#x, t1d#x, t1e#x, t1f#x, t1g#x, t1h#x, t1i#x]
   +- Filter t1b#x IN (list#x [t1b#x])
      :  +- Sort [min(t2b)#x ASC NULLS FIRST], true
      :     +- Aggregate [min(t2b#x) AS min(t2b)#x]
      :        +- Filter (outer(t1b#x) = t2b#x)
      :           +- SubqueryAlias t2
      :              +- View (`t2`, [t2a#x, t2b#x, t2c#x, t2d#x, t2e#x, t2f#x, t2g#x, t2h#x, t2i#x])
