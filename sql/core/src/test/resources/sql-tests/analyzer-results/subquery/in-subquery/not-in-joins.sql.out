         :              +- Project [cast(col1#x as string) AS t3a#x, cast(col2#x as int) AS t3b#x, cast(col3#x as int) AS t3c#x, cast(col4#x as int) AS t3d#x, cast(col5#x as decimal(3,1)) AS t3e#x, cast(col6#x as decimal(3,1)) AS t3f#x, cast(col7#x as double) AS t3g#x, cast(col8#x as timestamp) AS t3h#x, cast(col9#x as date) AS t3i#x]
         :                 +- LocalRelation [col1#x, col2#x, col3#x, col4#x, col5#x, col6#x, col7#x, col8#x, col9#x]
