-- !query
SELECT t1a,
       Count(DISTINCT( t1b ))
FROM   t1
WHERE  t1c IN (SELECT t2c
               FROM   t2
               WHERE  t1a = t2a)
GROUP  BY t1a,
          t1c
HAVING t1a = 't1b'
-- !query analysis
Filter (t1a#x = t1b)
+- Aggregate [t1a#x, t1c#x], [t1a#x, count(distinct t1b#x) AS count(DISTINCT t1b)#xL]
