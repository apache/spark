            +- LocalRelation [col1#x, col2#x, col3#x]


-- !query
SELECT t.symbol
FROM trades t ASOF JOIN quotes q
  MATCH_CONDITION (t.trade_time >= q.quote_time)
  ON t.symbol = q.symbol
EXCEPT
SELECT 'GOOG'
-- !query analysis
Except false
:- Project [symbol#x]
:  +- AsOfJoin (trade_time#x >= quote_time#x), (symbol#x = symbol#x), Inner
:     :- SubqueryAlias t
:     :  +- SubqueryAlias trades
:     :     +- View (`trades`, [trade_time#x, symbol#x, quantity#x])
:     :        +- Project [cast(col1#x as timestamp) AS trade_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as int) AS quantity#x]
:     :           +- LocalRelation [col1#x, col2#x, col3#x]
:     +- SubqueryAlias q
:        +- SubqueryAlias quotes
:           +- View (`quotes`, [quote_time#x, symbol#x, bid_price#x])
:              +- Project [cast(col1#x as timestamp) AS quote_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as decimal(5,2)) AS bid_price#x]
:                 +- LocalRelation [col1#x, col2#x, col3#x]
+- Project [GOOG AS GOOG#x]
   +- OneRowRelation


-- !query
SELECT l.trade_time, l.lateral_bid, a.asof_bid
FROM (
  SELECT t.trade_time, l.bid_price AS lateral_bid
  FROM trades t,
  LATERAL (
    SELECT q.bid_price
    FROM quotes q
    WHERE q.symbol = t.symbol AND q.quote_time <= t.trade_time
    ORDER BY q.quote_time DESC
    LIMIT 1
  ) l
  WHERE t.symbol = 'AAPL'
) l
JOIN (
  SELECT t.trade_time, q.bid_price AS asof_bid
  FROM trades t ASOF JOIN quotes q
    MATCH_CONDITION (t.trade_time >= q.quote_time)
    ON t.symbol = q.symbol
  WHERE t.symbol = 'AAPL'
) a ON l.trade_time = a.trade_time
ORDER BY l.trade_time
-- !query analysis
Sort [trade_time#x ASC NULLS FIRST], true
+- Project [trade_time#x, lateral_bid#x, asof_bid#x]
   +- Join Inner, (trade_time#x = trade_time#x)
      :- SubqueryAlias l
      :  +- Project [trade_time#x, bid_price#x AS lateral_bid#x]
      :     +- Filter (symbol#x = AAPL)
      :        +- LateralJoin lateral-subquery#x [symbol#x && trade_time#x], Inner
      :           :  +- SubqueryAlias l
      :           :     +- GlobalLimit 1
      :           :        +- LocalLimit 1
      :           :           +- Project [bid_price#x]
      :           :              +- Sort [quote_time#x DESC NULLS LAST], true
      :           :                 +- Project [bid_price#x, quote_time#x]
      :           :                    +- Filter ((symbol#x = outer(symbol#x)) AND (quote_time#x <= outer(trade_time#x)))
      :           :                       +- SubqueryAlias q
      :           :                          +- SubqueryAlias quotes
      :           :                             +- View (`quotes`, [quote_time#x, symbol#x, bid_price#x])
      :           :                                +- Project [cast(col1#x as timestamp) AS quote_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as decimal(5,2)) AS bid_price#x]
      :           :                                   +- LocalRelation [col1#x, col2#x, col3#x]
      :           +- SubqueryAlias t
      :              +- SubqueryAlias trades
      :                 +- View (`trades`, [trade_time#x, symbol#x, quantity#x])
      :                    +- Project [cast(col1#x as timestamp) AS trade_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as int) AS quantity#x]
      :                       +- LocalRelation [col1#x, col2#x, col3#x]
      +- SubqueryAlias a
         +- Project [trade_time#x, bid_price#x AS asof_bid#x]
            +- Filter (symbol#x = AAPL)
               +- AsOfJoin (trade_time#x >= quote_time#x), (symbol#x = symbol#x), Inner
                  :- SubqueryAlias t
                  :  +- SubqueryAlias trades
                  :     +- View (`trades`, [trade_time#x, symbol#x, quantity#x])
                  :        +- Project [cast(col1#x as timestamp) AS trade_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as int) AS quantity#x]
                  :           +- LocalRelation [col1#x, col2#x, col3#x]
                  +- SubqueryAlias q
                     +- SubqueryAlias quotes
                        +- View (`quotes`, [quote_time#x, symbol#x, bid_price#x])
                           +- Project [cast(col1#x as timestamp) AS quote_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as decimal(5,2)) AS bid_price#x]
                              +- LocalRelation [col1#x, col2#x, col3#x]


-- !query
SELECT *
FROM (
  SELECT t.symbol, q.bid_price, extract(hour FROM q.quote_time) AS h
  FROM trades t ASOF JOIN quotes q
    MATCH_CONDITION (t.trade_time >= q.quote_time)
    ON t.symbol = q.symbol
) PIVOT (max(bid_price) FOR h IN (10))
ORDER BY symbol
-- !query analysis
Sort [symbol#x ASC NULLS FIRST], true
+- Project [symbol#x, 10#x]
   +- Project [symbol#x, __pivot_max(__auto_generated_subquery_name.bid_price) AS `max(__auto_generated_subquery_name.bid_price)`#x[0] AS 10#x]
      +- Aggregate [symbol#x], [symbol#x, pivotfirst(h#x, max(__auto_generated_subquery_name.bid_price)#x, 10, 0, 0) AS __pivot_max(__auto_generated_subquery_name.bid_price) AS `max(__auto_generated_subquery_name.bid_price)`#x]
         +- Aggregate [symbol#x, h#x], [symbol#x, h#x, max(bid_price#x) AS max(__auto_generated_subquery_name.bid_price)#x]
            +- SubqueryAlias __auto_generated_subquery_name
               +- Project [symbol#x, bid_price#x, extract(hour, quote_time#x) AS h#x]
                  +- AsOfJoin (trade_time#x >= quote_time#x), (symbol#x = symbol#x), Inner
                     :- SubqueryAlias t
                     :  +- SubqueryAlias trades
                     :     +- View (`trades`, [trade_time#x, symbol#x, quantity#x])
                     :        +- Project [cast(col1#x as timestamp) AS trade_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as int) AS quantity#x]
                     :           +- LocalRelation [col1#x, col2#x, col3#x]
                     +- SubqueryAlias q
                        +- SubqueryAlias quotes
                           +- View (`quotes`, [quote_time#x, symbol#x, bid_price#x])
                              +- Project [cast(col1#x as timestamp) AS quote_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as decimal(5,2)) AS bid_price#x]
                                 +- LocalRelation [col1#x, col2#x, col3#x]


-- !query
SELECT symbol, hour_bucket, bid_price
FROM (
  SELECT t.symbol,
         CASE WHEN extract(hour FROM q.quote_time) = 10 THEN q.bid_price END AS hour_10
  FROM trades t ASOF JOIN quotes q
    MATCH_CONDITION (t.trade_time >= q.quote_time)
    ON t.symbol = q.symbol
) src
UNPIVOT (bid_price FOR hour_bucket IN (hour_10))
ORDER BY symbol, hour_bucket
-- !query analysis
Sort [symbol#x ASC NULLS FIRST, hour_bucket#x ASC NULLS FIRST], true
+- Project [symbol#x, hour_bucket#x, bid_price#x]
   +- Filter isnotnull(coalesce(bid_price#x))
      +- Expand [[symbol#x, hour_10, hour_10#x]], [symbol#x, hour_bucket#x, bid_price#x]
         +- SubqueryAlias src
            +- Project [symbol#x, CASE WHEN (extract(hour, quote_time#x) = 10) THEN bid_price#x END AS hour_10#x]
               +- AsOfJoin (trade_time#x >= quote_time#x), (symbol#x = symbol#x), Inner
                  :- SubqueryAlias t
                  :  +- SubqueryAlias trades
                  :     +- View (`trades`, [trade_time#x, symbol#x, quantity#x])
                  :        +- Project [cast(col1#x as timestamp) AS trade_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as int) AS quantity#x]
                  :           +- LocalRelation [col1#x, col2#x, col3#x]
                  +- SubqueryAlias q
                     +- SubqueryAlias quotes
                        +- View (`quotes`, [quote_time#x, symbol#x, bid_price#x])
                           +- Project [cast(col1#x as timestamp) AS quote_time#x, cast(col2#x as string) AS symbol#x, cast(col3#x as decimal(5,2)) AS bid_price#x]
                              +- LocalRelation [col1#x, col2#x, col3#x]
