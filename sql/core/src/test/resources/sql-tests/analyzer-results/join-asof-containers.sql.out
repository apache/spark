-- !query
UPDATE asof_update_tgt AS tgt
SET bid_price = (
  SELECT q.bid_price
  FROM trades t ASOF JOIN quotes q
    MATCH_CONDITION (t.trade_time >= q.quote_time)
    ON t.symbol = q.symbol
  WHERE t.trade_time = tgt.trade_time AND t.symbol = tgt.symbol
)
