-- !query
SELECT bin_start, SUM(value) AS total
FROM metrics BIN BY (
  RANGE ts_start TO ts_end
  BIN WIDTH INTERVAL '5' MINUTE
  ALIGN TO TIMESTAMP '2024-01-01 00:00:00'
  DISTRIBUTE UNIFORM (value)
)
