-- !query
SELECT t.symbol, q.bid_price
FROM trades t ASOF JOIN quotes q
  MATCH_CONDITION (t.trade_time >= q.quote_time)
  ON t.symbol = q.symbol
WHERE q.bid_price > 200
ORDER BY t.symbol
-- !query schema
struct<symbol:string,bid_price:decimal(5,2)>
-- !query output
MSFT	420.50


