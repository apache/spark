-- !query
SELECT count(*) AS cnt
FROM trades t ASOF JOIN (SELECT * FROM quotes WHERE 1 = 0) q
  MATCH_CONDITION (t.trade_time >= q.quote_time)
  ON t.symbol = q.symbol
